# Credenciales de Cloudflare R2
# Obtén estos valores en: https://dash.cloudflare.com → R2 → Manage R2 API Tokens
#
# PASOS:
# 1. Ve a https://dash.cloudflare.com
# 2. Sección R2 Object Storage
# 3. Crea un bucket llamado "chispito-libros"
# 4. En el bucket → Settings → Public Access → habilita "Allow Access"
# 5. Copia la "Public Bucket URL" (algo como https://pub-XXXX.r2.dev)
# 6. Ve a R2 → Overview → Manage R2 API Tokens → Create API Token
# 7. Permisos: Object Read & Write → Apply to specific bucket: chispito-libros
# 8. Copia Account ID, Access Key ID y Secret Access Key

R2_ACCOUNT_ID=TU_ACCOUNT_ID_AQUI
R2_ACCESS_KEY_ID=TU_ACCESS_KEY_AQUI
R2_SECRET_ACCESS_KEY=TU_SECRET_KEY_AQUI
R2_BUCKET_NAME=chispito-libros
R2_PUBLIC_URL=https://pub-XXXXXXXXXXXXXXXXXXXXXXXXXX.r2.dev
